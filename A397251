from sympy import divisors, factorint
from functools import lru_cache
from fractions import Fraction
from multiprocessing import Pool, cpu_count


@lru_cache(maxsize=None)
def sigma(n: int) -> int:
    return sum(divisors(n))


@lru_cache(maxsize=None)
def dedekind_psi(n: int) -> Fraction:
    factors = factorint(n)
    result = Fraction(n, 1)
    for p in factors:
        result *= Fraction(p + 1, p)
    return result


def process_pair(xy):
    """Find all (x,y,z,t) such that
    sigma(x)*psi(x)^2 = sigma(y)*psi(y)^2
    = x^3+y^3+z^3+t^3
    """
    x, y = xy
    quadruples = []

    fval_x = sigma(x) * dedekind_psi(x) ** 2
    fval_y = sigma(y) * dedekind_psi(y) ** 2

    if fval_x.denominator != 1 or fval_y.denominator != 1:
        return quadruples
    if fval_x != fval_y:
        return quadruples

    target = fval_x.numerator

    rhs = target - (x**3 + y**3)
    if rhs < 0:
        return quadruples

    max_z = int(round(rhs ** (1 / 3))) + 1
    for z in range(1, max_z + 1):
        rem = rhs - z**3
        if rem < 0:
            break
        t = round(rem ** (1 / 3))
        if t >= z and t**3 == rem:
            quadruples.append((x, y, z, t))

    return quadruples


def find_xyzt_quadruples(start, end):
    pairs = [(x, y) for x in range(start, end + 1)
                    for y in range(x, end + 1)]

    with Pool(cpu_count()) as pool:
        results = pool.map(process_pair, pairs)

    quadruples = [q for sublist in results for q in sublist]
    return quadruples


if __name__ == "__main__":
    start = 1
    end = 1000

    xyzt_quadruples = find_xyzt_quadruples(start, end)

    for quadruple in xyzt_quadruples:
        print(f"({quadruple[0]}, {quadruple[1]}, {quadruple[2]}, {quadruple[3]})")

    print(f"Number of quadruples found: {len(xyzt_quadruples)}")

    x_values = sorted({q[0] for q in xyzt_quadruples})

    if x_values:
        print("Sequence of x-values:")
        print(", ".join(map(str, x_values)))
        print(f"Number of distinct x-values: {len(x_values)}")
